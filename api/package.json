{
  "name": "villageapi-backend",
  "version": "1.0.0",
  "description": "VillageAPI — B2B SaaS REST API for India's village-level geographical data",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "prisma:generate": "npx prisma generate --schema=../prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=../prisma/schema.prisma",
    "prisma:studio": "npx prisma studio --schema=../prisma/schema.prisma"
  },
  "dependencies": {
    "express": "^4.18.2",
    "@prisma/client": "^5.10.0",
    "prisma": "^5.10.0",
    "ioredis": "^5.3.2",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "nodemailer": "^6.9.8",
    "dotenv": "^16.4.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "@types/node": "^20.11.10"
  }
}
